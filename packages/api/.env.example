# ═══════════════════════════════════════════════════════════════
# TenantScale API — Environment Variables
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ═══════════════════════════════════════════════════════════════
# REQUIRED
# ═══════════════════════════════════════════════════════════════

# Supabase project URL (e.g. https://rxclwxvyoejzvrnnhlsn.supabase.co)
SUPABASE_URL=

# Supabase service_role key (NOT the anon key — needs admin privileges)
SUPABASE_SERVICE_ROLE_KEY=

# ═══════════════════════════════════════════════════════════════
# SERVER
# ═══════════════════════════════════════════════════════════════

# Port the API server listens on (default: 3001)
# PORT=3001

# Log level: trace, debug, info, warn, error, fatal (default: info)
# LOG_LEVEL=info

# Comma-separated list of allowed CORS origins (default: localhost dev ports)
# Restrict in production to your actual domains.
# CORS_ORIGIN=https://app.tenantscale.com,https://admin.tenantscale.com

# Deployment label for telemetry (default: development)
# DEPLOYMENT_MODE=production

# ═══════════════════════════════════════════════════════════════
# ERROR TRACKING (Sentry — optional)
# ═══════════════════════════════════════════════════════════════

# Sentry DSN for error tracking. If unset, Sentry is disabled.
# SENTRY_DSN=https://xxx@xxx.ingest.us.sentry.io/xxx

# Sentry traces sample rate (0.0 to 1.0, default: 0.1)
# SENTRY_TRACES_SAMPLE_RATE=0.1

# ═══════════════════════════════════════════════════════════════
# STRIPE BILLING (optional — required for subscription features)
# ═══════════════════════════════════════════════════════════════

# Stripe secret key (starts with sk_live_ or sk_test_)
# STRIPE_SECRET_KEY=sk_test_xxx

# Stripe webhook signing secret (starts with whsec_)
# STRIPE_WEBHOOK_SECRET=whsec_xxx

# Stripe price IDs for each plan tier and billing interval.
# Create these in the Stripe dashboard first, then set them here.
# STRIPE_PRICE_HOBBY_MONTH=price_xxx
# STRIPE_PRICE_HOBBY_YEAR=price_xxx
# STRIPE_PRICE_PRO_MONTH=price_xxx
# STRIPE_PRICE_PRO_YEAR=price_xxx
# STRIPE_PRICE_SCALE_MONTH=price_xxx
# STRIPE_PRICE_SCALE_YEAR=price_xxx

# ═══════════════════════════════════════════════════════════════
# CRON / ALERTING (optional)
# ═══════════════════════════════════════════════════════════════

# Secret key for authenticating the /v1/admin/cron/check-alerts endpoint.
# Set this to a random string, then call the endpoint with it as a header.
# CRON_SECRET=your-cron-secret
