{
  "name": "@tenantscale/api",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && node scripts/build-vercel-bundle.js && node scripts/fix-extensions.js",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js",
    "test": "vitest run",
    "stripe:setup-products": "tsx src/scripts/setup-stripe-products.ts",
    "lint": "eslint src/",
    "seed": "tsx src/scripts/seed.ts"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.11",
    "@hono/zod-validator": "^0.9.0",
    "@sentry/node": "^10.67.0",
    "@supabase/supabase-js": "^2.110.8",
    "@tenantscale/sdk": "^0.4.0",
    "hono": "^4.12.31",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "stripe": "^22.3.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "26.1.1",
    "@vitest/coverage-v8": "^4.1.10",
    "dotenv": "^17.4.2",
    "esbuild": "^0.28.1",
    "eslint": "^10.7.0",
    "tsx": "^4.23.1",
    "@typescript/native": "npm:typescript@7.0.2",
    "typescript": "npm:@typescript/typescript6@^6.0.1",
    "typescript-eslint": "^8.65.0",
    "vitest": "4.1.10"
  }
}
