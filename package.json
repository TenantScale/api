{
  "name": "tenantscale-cloud",
  "private": true,
  "scripts": {
    "dev:portal": "pnpm --filter @tenantscale/portal dev",
    "dev:admin": "pnpm --filter @tenantscale/admin dev",
    "build:portal": "pnpm --filter @tenantscale/portal build",
    "build:admin": "pnpm --filter @tenantscale/admin build",
    "lint": "turbo lint",
