# ──────────────────────────────────────────────────────
# TenantScale API — Environment Configuration
# ──────────────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Docs: https://github.com/TenantScale/api/docs/self-hosting.md

# ── Required ──────────────────────────────────────────
# Supabase project URL (or local Supabase instance).
# Get this from your Supabase dashboard: Settings → API → Project URL
SUPABASE_URL=

# Supabase service_role key (NOT the anon key — this has admin access).
# Get this from: Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=

# ── Server ────────────────────────────────────────────
# Port the API listens on inside the container.
# Map it to a host port via docker-compose or -p 4000:3001.
PORT=3001

# Log level: trace, debug, info, warn, error, fatal
LOG_LEVEL=info

# Deployment mode — used in the /v1/status endpoint for diagnostics.
# Set by the Docker entrypoint automatically; override if needed.
# DEPLOYMENT_MODE=self_hosted

# ── CORS ──────────────────────────────────────────────
# Comma-separated list of allowed origins, or * for any.
# In production, restrict this to your Portal domain.
CORS_ORIGIN=*

# ── Optional: Stripe (Billing) ────────────────────────
# Omit these to disable billing — the API will return 501
# on subscription and checkout routes.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Price IDs from your Stripe dashboard (look up after creating products)
# Format: price_xxxxxxxxxxxxx
# STRIPE_PRICE_HOBBY_MONTH=
# STRIPE_PRICE_HOBBY_YEAR=
# STRIPE_PRICE_PRO_MONTH=
# STRIPE_PRICE_PRO_YEAR=
# STRIPE_PRICE_SCALE_MONTH=
# STRIPE_PRICE_SCALE_YEAR=

# Redirect URLs for Stripe Checkout & Customer Portal
# STRIPE_SUCCESS_URL=http://localhost:3000/success
# STRIPE_CANCEL_URL=http://localhost:3000
# STRIPE_PORTAL_RETURN_URL=http://localhost:3000/settings

# ── Optional: Sentry (Error Tracking) ─────────────────
# Omit to disable Sentry — errors still log to stdout via pino.
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# ── Optional: Cron / Internal Alerts ──────────────────
# Used for scheduled tasks (retention cleanup, usage reports).
# Set a random secret and call POST /v1/cron/run?secret=<value>.
CRON_SECRET=

# ── Optional: Webhooks ────────────────────────────────
# Set to "true" to log webhook request/response bodies (debug only).
# WEBHOOK_LOG_BODIES=false
